# Phase 1 daily default.
FINDINGALPHA_PROVIDER=yfinance

# Alpaca market data only. Do not put real keys in this example file.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=

# Alpaca's docs and SDKs also commonly use these APCA_* names.
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=

# Use iex for Alpaca Basic/free data. SIP may require paid access.
ALPACA_DATA_FEED=iex

# Optional later providers:
MASSIVE_API_KEY=
MASSIVE_RATE_LIMIT_SLEEP_SECONDS=13
ALPHA_VANTAGE_API_KEY=
FMP_API_KEY=
TIINGO_API_KEY=
POLYGON_API_KEY=
FINNHUB_API_KEY=
BENZINGA_API_KEY=
NASDAQ_DATA_LINK_API_KEY=

# SEC EDGAR requires a descriptive User-Agent when used later.
SEC_USER_AGENT="FindingAlpha personal-research contact@example.com"

# Broker credentials are intentionally excluded from phase 1.
